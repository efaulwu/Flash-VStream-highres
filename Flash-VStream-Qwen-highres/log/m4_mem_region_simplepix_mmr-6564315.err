[[bash:71] : -s sh
[bash:71] eval
[slurm_script:23] '[' -n /scratch/zwu24/singularity_sifs/qwen.sif ']'
[slurm_script:23] '[' -f /scratch/zwu24/singularity_sifs/qwen.sif ']'
[slurm_script:24] singularity exec --nv -e --bind /scratch:/scratch --pwd /scratch/zwu24/Flash-VStream-highres/Flash-VStream-Qwen-highres /scratch/zwu24/singularity_sifs/qwen.sif bash -lc '
